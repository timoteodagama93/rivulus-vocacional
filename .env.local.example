# ============================================================
# RIVULUS VOCACIONAL — Variáveis de Ambiente
# Renomear este ficheiro para .env.local
# NUNCA fazer commit deste ficheiro com valores reais
# ============================================================

# Firebase (obter em: console.firebase.google.com > Project Settings)
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=

# Firebase Admin (Netlify Functions — JSON da service account em base64 ou inline)
FIREBASE_SERVICE_ACCOUNT=

# Gemini API (obter em: aistudio.google.com)
GEMINI_API_KEY=

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME=Rivulus Vocacional
